[project]
name = "{{ project_name_hyphenated }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
requires-python = ">=3.13"
dependencies = [
    "fastapi>=0.115.0",
    "uvicorn>=0.30.0",
    "pydantic-settings>=2.4.0",
    "fastapi-swagger-ui-theme>=0.1.0",
    "sqlalchemy>=2.0.32",
    "aiosqlite>=0.20.0",
    {% if use_llm %}"httpx>=0.27.0",{% endif %}
]

[tool.pytest.ini_options]
asyncio_mode = "auto"

[build-system]
requires = ["uv_build>=0.10.5,<0.11.0"]
build-backend = "uv_build"
