# Base configuration
TZ=<TZ>
SERVER_HOST=0.0.0.0
API_PORT=8000
SERVER_MODE=production
LOG_LEVEL=INFO
TEMP_PATH=./tmp

{% if use_llm %}
# LLM 
LLM_HOST=your_llm_host
LLM_PORT=80
LLM_SECURE=false
LLM_API_KEY=your_api_key
LLM_MODEL=your_llm_model
{% endif %}

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/{{ project_name }}.db
